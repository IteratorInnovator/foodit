# Kafka/MSK Configuration
KAFKA_BROKERS=<broker1:port,broker2:port,broker3:port>
KAFKA_GROUP_ID=<consumer-group-id>

# MSK Authentication: "none", "iam", or "scram"
MSK_AUTH_MECHANISM=<none|iam|scram>

# For IAM authentication
AWS_REGION=<aws-region>

# For SCRAM authentication
MSK_USERNAME=<scram-username>
MSK_PASSWORD=<scram-password>

# Service URLs
CHAT_SERVICE_URL=<chat-service-url>
LOCATION_SERVICE_URL=<location-service-url>
